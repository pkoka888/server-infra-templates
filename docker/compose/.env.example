# Example environment file for docker/compose/app.yml
# Copy to .env and fill in values

# =============================================================================
# REGISTRY & IMAGE
# =============================================================================
REGISTRY=ghcr.io
IMAGE_NAME=myapp
IMAGE_TAG=latest

# =============================================================================
# PROJECT
# =============================================================================
PROJECT_NAME=myproject

# =============================================================================
# APPLICATION
# =============================================================================
APP_ENV=production
LOG_LEVEL=info
HEALTH_PORT=8080
HOST_PORT=8080
CONTAINER_PORT=8080

# =============================================================================
# SECURITY (REQUIRED)
# =============================================================================
APP_USER=appuser
APP_GROUP=appgroup

# =============================================================================
# RESOURCES
# =============================================================================
MEMORY_LIMIT=512M
CPU_LIMIT=0.5

# =============================================================================
# DATABASE
# =============================================================================
DB_NAME=app
DB_USER=appuser
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
