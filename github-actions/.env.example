# Example environment file for GitHub Actions workflows
# Add these as GitHub repository secrets

# =============================================================================
# PRODUCTION SERVER
# =============================================================================
PRODUCTION_HOST=your-server.com
PRODUCTION_USER=deploy
# PRODUCTION_SSH_KEY - Add as secret (private key)

# =============================================================================
# REGISTRY (if not GitHub Container Registry)
# =============================================================================
REGISTRY=docker.io
REGISTRY_USERNAME=your-username
# REGISTRY_PASSWORD - Add as secret

# =============================================================================
# SLACK NOTIFICATIONS (optional)
# =============================================================================
# SLACK_WEBHOOK - Add as secret
