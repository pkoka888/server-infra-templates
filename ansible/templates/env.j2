# Metabase Database Configuration
MB_DB_TYPE=postgres
MB_DB_DBNAME=metabase
MB_DB_PORT=5432
MB_DB_HOST=metabase-db
MB_DB_USER={{ vault_mb_db_user }}
MB_DB_PASS={{ vault_mb_db_pass }}

# Java Timezone
JAVA_TIMEZONE=Europe/Prague
TZ=Europe/Prague

# Metabase Settings
MB_JETTY_MAX_THREADS=25
MB_APPLICATION_DB_MAX_CONNECTION_POOL_SIZE=25
MB_PROMETHEUS_ENABLED=true
MB_LIVENESS_CHECK_ENABLED=true
MB_ANALYTICS_ENABLED=false
JAVA_TOOL_OPTIONS=-Xmx2g -Xms1g

# Prefect
PREFECT_API_URL=http://prefect-server:4200/api
