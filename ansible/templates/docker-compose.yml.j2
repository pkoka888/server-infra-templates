version: "3.8"

services:
  metabase:
    image: metabase/metabase:v0.59.5
    container_name: metabase
    restart: unless-stopped
    ports:
      - "127.0.0.1:8096:3000"
    environment:
      MB_DB_TYPE: postgres
      MB_DB_DBNAME: metabase
      MB_DB_PORT: 5432
      MB_DB_HOST: metabase-db
      MB_DB_USER: {{ vault_mb_db_user }}
      MB_DB_PASS: {{ vault_mb_db_pass }}
      JAVA_TIMEZONE: Europe/Prague
      TZ: Europe/Prague
      JAVA_TOOL_OPTIONS: "-Xmx2g -Xms1g"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3000/api/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 120s
    networks:
      - metabase-net
    depends_on:
      metabase-db:
        condition: service_healthy

  metabase-db:
    image: postgres:17-alpine
    container_name: metabase-db
    restart: unless-stopped
    environment:
      POSTGRES_DB: metabase
      POSTGRES_USER: {{ vault_postgres_user }}
      POSTGRES_PASSWORD: {{ vault_postgres_password }}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ vault_postgres_user }} -d metabase"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - metabase-net

  prefect-server:
    image: prefecthq/prefect:3-latest
    container_name: prefect-server
    restart: unless-stopped
    ports:
      - "127.0.0.1:4200:4200"
    environment:
      PREFECT_HOME: /data
    networks:
      - metabase-net

  prefect-worker:
    image: prefecthq/prefect:3-latest
    container_name: prefect-worker
    restart: unless-stopped
    command: prefect worker start --pool docker --type docker
    environment:
      PREFECT_API_URL: http://prefect-server:4200/api
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - metabase-net
    depends_on:
      prefect-server:
        condition: service_healthy

volumes:
  metabase-db-data:
  prefect-data:

networks:
  metabase-net:
    driver: bridge
