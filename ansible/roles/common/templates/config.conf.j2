# {{ role_name | default('myapp') }} configuration
# Copy to roles/{role_name}/templates/config.conf.j2

server {
    listen {{ role_port | default(8080) }};
    server_name {{ role_domain | default('localhost') }};

    location / {
        proxy_pass http://localhost:{{ role_backend_port | default(3000) }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
