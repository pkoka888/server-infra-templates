# dlt Pipeline Configuration

# Copy this file for each client:
#   cp .env.example .env.client1
#   cp .env.example .env.client2

# ============================================
# PostgreSQL Destination (same for all clients)
# ============================================
POSTGRES_HOST=metabase-db
POSTGRES_PORT=5432
POSTGRES_USER=metabase
POSTGRES_PASSWORD=<from .env>
POSTGRES_DATABASE=metabase

# ============================================
# Client ID (used in dataset names)
# ============================================
CLIENT_ID=client1

# ============================================
# Google Analytics 4
# ============================================
# Get from Google Analytics Admin → Property Settings → Property ID
GA4_PROPERTY_ID=123456789

# Create in Google Cloud Console → Credentials → OAuth 2.0 Client
GA4_CLIENT_ID=xxxxx.apps.googleusercontent.com
GA4_CLIENT_SECRET=
GA4_REFRESH_TOKEN=

# Project ID from GCP
GA4_PROJECT_ID=my-project-12345

# ============================================
# Google Ads
# ============================================
# Get from Google Ads → Tools → API Center
GADS_DEVELOPER_TOKEN=

# OAuth2 credentials from GCP
GADS_CLIENT_ID=
GADS_CLIENT_SECRET=
GADS_REFRESH_TOKEN=

# Customer ID (MCC or individual account, no dashes)
GADS_CUSTOMER_ID=1234567890

# ============================================
# Facebook/Meta Ads
# ============================================
# Get from Meta Business Manager → Business Settings → Data Sources
FB_AD_ACCOUNT_ID=act_1234567890123456

# Get from Meta Developers → My Apps → Marketing API
FB_ACCESS_TOKEN=

# ============================================
# PrestaShop
# ============================================
PS_SHOP_URL=https://mystore.com
PS_API_KEY=<your_prestashop_api_key>

# ============================================
# Google Search Console
# ============================================
GSC_PROPERTY_URL=https://mystore.com/
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REFRESH_TOKEN=

# ============================================
# SEO Tools (Ahrefs, SEMrush)
# ============================================
AHREFS_API_KEY=
SEMRUSH_API_KEY=