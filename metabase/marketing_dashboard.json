  "parameters": [
    {
      "id": "date_range",
      "type": "date/range",
      "target": ["dimension", ["field", 123, null]],
      "name": "Date Range",
      "slug": "date_range",
      "default": "past30days",
      "required": true
    },
    {
      "id": "channel_grouping",
      "type": "string/=",
      "target": ["dimension", ["field", 456, null]],
      "name": "Channel Grouping",
      "slug": "channel_grouping",
      "default": null,
      "required": false
    }
  ],
  "cards": [
    {
      "id": 1,
      "name": "Total Revenue",
      "display": "scalar",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT SUM(total_revenue) FROM marts.fct_marketing_performance WHERE date_day >= {{date_range}}"
        },
        "database": 1
      },
      "visualization_settings": {
        "column_settings": {},
        "scalar": {
          "prefix": "€",
          "suffix": "",
          "decimals": 0,
          "compact": true
        }
      },
      "size_x": 4,
      "size_y": 3,
      "row": 0,
      "col": 0
    },
    {
      "id": 2,
      "name": "Total ROAS",
      "display": "scalar",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT CASE WHEN SUM(total_cost) > 0 THEN SUM(total_revenue) / SUM(total_cost) ELSE NULL END FROM marts.fct_marketing_performance WHERE date_day >= {{date_range}} AND total_cost > 0"
        },
        "database": 1
      },
      "visualization_settings": {
        "scalar": {
          "prefix": "",
          "suffix": "x",
          "decimals": 2,
          "compact": false
        },
        "click_behavior": null
      },
      "size_x": 4,
      "size_y": 3,
      "row": 0,
      "col": 4
    },
    {
      "id": 3,
      "name": "Conversion Rate",
      "display": "scalar",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT CASE WHEN SUM(total_sessions) > 0 THEN 100.0 * SUM(total_conversions) / SUM(total_sessions) ELSE NULL END FROM marts.fct_marketing_performance WHERE date_day >= {{date_range}}"
        },
        "database": 1
      },
      "visualization_settings": {
        "scalar": {
          "prefix": "",
          "suffix": "%",
          "decimals": 2,
          "compact": false
        }
      },
      "size_x": 4,
      "size_y": 3,
      "row": 0,
      "col": 8
    },
    {
      "id": 4,
      "name": "Total Sessions",
      "display": "scalar",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT SUM(total_sessions) FROM marts.fct_marketing_performance WHERE date_day >= {{date_range}}"
        },
        "database": 1
      },
      "visualization_settings": {
        "scalar": {
          "prefix": "",
          "suffix": "",
          "decimals": 0,
          "compact": true
        }
      },
      "size_x": 4,
      "size_y": 3,
      "row": 0,
      "col": 12
    },
    {
      "id": 5,
      "name": "Revenue by Channel (Time Series)",
      "display": "line",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT date_day, channel_grouping, SUM(total_revenue) as revenue FROM marts.fct_marketing_performance WHERE date_day >= {{date_range}} GROUP BY 1, 2 ORDER BY 1"
        },
        "database": 1
      },
      "visualization_settings": {
        "graph": {
          "dimensions": ["date_day", "channel_grouping"],
          "metrics": ["revenue"],
          "show_values": false,
          "stackable": {
            "stack_type": "stacked"
          },
          "x_axis": {
            "title_text": "Date"
          },
          "y_axis": {
            "title_text": "Revenue (€)",
            "prefix": "€"
          }
        }
      },
      "size_x": 12,
      "size_y": 6,
      "row": 3,
      "col": 0
    },
    {
      "id": 6,
      "name": "Channel Performance Breakdown",
      "display": "table",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT channel_grouping, source, SUM(total_sessions) as sessions, SUM(total_conversions) as conversions, SUM(total_revenue) as revenue, SUM(total_cost) as cost, CASE WHEN SUM(total_cost) > 0 THEN SUM(total_revenue) / SUM(total_cost) ELSE NULL END as roas, CASE WHEN SUM(total_sessions) > 0 THEN 100.0 * SUM(total_conversions) / SUM(total_sessions) ELSE NULL END as conversion_rate FROM marts.fct_marketing_performance WHERE date_day >= {{date_range}} GROUP BY 1, 2 ORDER BY revenue DESC"
        },
        "database": 1
      },
      "visualization_settings": {
        "column_settings": {
          "revenue": {
            "column_title": "Revenue",
            "number_style": "currency",
            "currency": "EUR"
          },
          "cost": {
            "column_title": "Cost",
            "number_style": "currency",
            "currency": "EUR"
          },
          "roas": {
            "column_title": "ROAS",
            "number_style": "decimal",
            "decimals": 2,
            "suffix": "x"
          },
          "conversion_rate": {
            "column_title": "Conv. Rate",
            "number_style": "percent",
            "decimals": 2
          }
        }
      },
      "size_x": 12,
      "size_y": 8,
      "row": 9,
      "col": 0
    },
    {
      "id": 7,
      "name": "Daily Trend - Sessions vs Conversions",
      "display": "combo",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT date_day, SUM(total_sessions) as sessions, SUM(total_conversions) as conversions FROM marts.fct_marketing_performance WHERE date_day >= {{date_range}} GROUP BY 1 ORDER BY 1"
        },
        "database": 1
      },
      "visualization_settings": {
        "graph": {
          "dimensions": ["date_day"],
          "metrics": ["sessions", "conversions"],
          "series_settings": {
            "sessions": {
              "display": "line",
              "axis": "left"
            },
            "conversions": {
              "display": "bar",
              "axis": "right",
              "color": "#509EE3"
            }
          }
        }
      },
      "size_x": 12,
      "size_y": 6,
      "row": 17,
      "col": 0
    },
    {
      "id": 8,
      "name": "Top Campaigns by Revenue",
      "display": "bar",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT campaign, SUM(total_revenue) as revenue FROM marts.fct_marketing_performance WHERE date_day >= {{date_range}} AND campaign IS NOT NULL GROUP BY 1 ORDER BY revenue DESC LIMIT 10"
        },
        "database": 1
      },
      "visualization_settings": {
        "graph": {
          "x_axis": {
            "title_text": "Campaign"
          },
          "y_axis": {
            "title_text": "Revenue (€)",
            "prefix": "€"
          }
        }
      },
      "size_x": 12,
      "size_y": 6,
      "row": 23,
      "col": 0
    },
    {
      "id": 9,
      "name": "Cost vs Revenue by Channel",
      "display": "bar",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT channel_grouping, SUM(total_cost) as cost, SUM(total_revenue) as revenue FROM marts.fct_marketing_performance WHERE date_day >= {{date_range}} GROUP BY 1 ORDER BY revenue DESC"
        },
        "database": 1
      },
      "visualization_settings": {
        "graph": {
          "dimensions": ["channel_grouping"],
          "metrics": ["cost", "revenue"],
          "stackable": {
            "stack_type": "grouped"
          },
          "series_settings": {
            "cost": {
